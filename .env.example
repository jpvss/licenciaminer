# Diretório base de dados (padrão: ./data)
# DATA_DIR=./data

# Caminho do banco DuckDB (padrão: ./data/licenciaminer.duckdb)
# DB_PATH=./data/licenciaminer.duckdb

# URLs das fontes (sobrescrever se endpoints mudarem)
# IBAMA_SISLIC_URL=https://dadosabertos.ibama.gov.br/dados/SISLIC/sislic-licencas.json
# ANM_FEATURESERVER_URL=https://geo.anm.gov.br/arcgis/rest/services/SIGMINE/dados_anm/FeatureServer/0/query

# ── API & Chat ──
# ANTHROPIC_API_KEY=sk-ant-...

# ── Next.js Frontend (set in Vercel dashboard) ──
# NEXT_PUBLIC_API_URL=https://your-app.railway.app/api
